{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/acoustesh/pykissembed/schemas/baselines.v1.json",
  "title": "pykissembed baseline envelope v1",
  "description": "Versioned wrapper for all pykissembed baseline JSON files. The inner 'data' payload is shape-specific per 'kind'.",
  "type": "object",
  "required": ["schema_version", "kind", "data"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "enum": [
        "lint_typecheck",
        "complexity",
        "density",
        "docstring_format",
        "similarity",
        "comment_density_config"
      ]
    },
    "data": {
      "type": "object"
    }
  }
}